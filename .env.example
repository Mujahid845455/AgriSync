# Frontend Environment Variables Template
# Copy this file to .env.local for development
# Copy this file to .env.production for production

# API Base URL - Change this for production deployment
VITE_API_BASE_URL=http://localhost:5000/api

# App Information
VITE_APP_NAME=AgriSync
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Agricultural Inventory & Account Reconciliation Management System

# Build Configuration
VITE_BUILD_MODE=production